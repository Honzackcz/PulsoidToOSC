<Application
    x:Class="PulsoidToOSC.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:PulsoidToOSC"
    xmlns:vm="clr-namespace:PulsoidToOSC.ViewModels.Options"
    xmlns:views="clr-namespace:PulsoidToOSC.Windows.Options"
    ThemeMode="System">

    <Application.Resources>
        <ResourceDictionary>
            <DataTemplate DataType="{x:Type vm:GeneralViewModel}">
                <views:General/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:HeartRateViewModel}">
                <views:HeartRate/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:OSCViewModel}">
                <views:OSC/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ParametersViewModel}">
                <views:Parameters/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ToolsViewModel}">
                <views:Tools/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:UIViewModel}">
                <views:UI/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:VRChatViewModel}">
                <views:VRChat/>
            </DataTemplate>

            <local:LocaleUI x:Key="Locale"/>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PresentationFramework.Fluent;component/Themes/Fluent.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>