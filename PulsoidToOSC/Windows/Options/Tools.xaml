<UserControl x:Class="PulsoidToOSC.Windows.Options.Tools"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:PulsoidToOSC.ViewModels.Options"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="400"
			 d:DataContext="{d:DesignInstance Type=local:ToolsViewModel}">
	<Grid>
		<ScrollViewer>
			<StackPanel Margin="4,4,12,4">
				<TextBlock
					Margin="16"
					VerticalAlignment="Center"
					TextWrapping="Wrap"
					Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Tools.Title]}"
					Style="{StaticResource TitleTextBlockStyle}"
				/>

				<Border Margin="4" Padding="4" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<StackPanel>
						<TextBlock
							Margin="8"
							VerticalAlignment="Center"
							TextWrapping="Wrap"
							Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Tools.HeartRateTesting.Title]}"
							Style="{StaticResource SubtitleTextBlockStyle}"
						/>
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<Button
								Grid.Column="0"
								Margin="4"
								HorizontalAlignment="Stretch"
								IsEnabled="{Binding TestHeartRateButtonEnabled}"
								Command="{Binding TestHeartRateCommand}"
								Content="{Binding TestHeartRateButtonContent}"
								ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Tools.HeartRateTesting.Tooltip]}"
							/>
							<TextBlock
								Grid.Column="1"
								Margin="8"
								VerticalAlignment="Center"
								TextWrapping="Wrap"
								Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Tools.HeartRateTesting.Text]}"
							/>
						</Grid>

						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="100"/>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="100"/>
							</Grid.ColumnDefinitions>

							<TextBlock
								Grid.Row="0"
								Grid.Column="0"
								Margin="8"
								VerticalAlignment="Center"
								HorizontalAlignment="Right"
								Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Tools.HeartRateTesting.Min]}"
							/>
							<TextBox
								Grid.Row="0"
								Grid.Column="1"
								Margin="4"
								Text="{Binding MinHeartRate, UpdateSourceTrigger=PropertyChanged}"
								ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Tools.HeartRateTesting.Min.Tooltip]}"
							>
								<TextBox.InputBindings>
									<KeyBinding Key="Enter" Command="{Binding OptionsToolsApplyCommand}"/>
								</TextBox.InputBindings>
							</TextBox>

							<TextBlock
								Grid.Row="0"
								Grid.Column="2"
								Margin="8"
								VerticalAlignment="Center"
								HorizontalAlignment="Right"
								Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Tools.HeartRateTesting.Max]}"
							/>
							<TextBox
								Grid.Row="0"
								Grid.Column="3"
								Margin="4"
								Text="{Binding MaxHeartRate, UpdateSourceTrigger=PropertyChanged}"
								ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Tools.HeartRateTesting.Max.Tooltip]}"
							>
								<TextBox.InputBindings>
									<KeyBinding Key="Enter" Command="{Binding OptionsToolsApplyCommand}"/>
								</TextBox.InputBindings>
							</TextBox>

							<TextBlock
								Grid.Row="1"
								Grid.Column="0"
								Margin="8"
								VerticalAlignment="Center"
								HorizontalAlignment="Right"
								Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Tools.HeartRateTesting.Step]}"
							/>
							<TextBox
								Grid.Row="1"
								Grid.Column="1"
								Margin="4"
								Text="{Binding IncrementStep, UpdateSourceTrigger=PropertyChanged}"
								ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Tools.HeartRateTesting.Step.Tooltip]}"
							>
								<TextBox.InputBindings>
									<KeyBinding Key="Enter" Command="{Binding OptionsToolsApplyCommand}"/>
								</TextBox.InputBindings>
							</TextBox>

							<TextBlock
								Grid.Row="1"
								Grid.Column="2"
								Margin="8"
								VerticalAlignment="Center"
								HorizontalAlignment="Right"
								Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Tools.HeartRateTesting.Interval]}"
							/>
							<TextBox
								Grid.Row="1"
								Grid.Column="3"
								Margin="4"
								Text="{Binding IncrementInterval, UpdateSourceTrigger=PropertyChanged}"
								ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Tools.HeartRateTesting.Interval.Tooltip]}"
							>
								<TextBox.InputBindings>
									<KeyBinding Key="Enter" Command="{Binding OptionsToolsApplyCommand}"/>
								</TextBox.InputBindings>
							</TextBox>
						</Grid>
					</StackPanel>
				</Border>

			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
