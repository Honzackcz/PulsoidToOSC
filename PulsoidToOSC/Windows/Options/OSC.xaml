<UserControl x:Class="PulsoidToOSC.Windows.Options.OSC"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:PulsoidToOSC.ViewModels.Options"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="400"
			 d:DataContext="{d:DesignInstance Type=local:OSCViewModel}">
	<Grid>
		<ScrollViewer>
			<StackPanel Margin="4,4,12,4">
				<TextBlock
					Margin="16"
					VerticalAlignment="Center"
					TextWrapping="Wrap"
					Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.OSC.Title]}"
					Style="{StaticResource TitleTextBlockStyle}"
				/>
				
				<Border Margin="4,4,4,0" Padding="4" CornerRadius="4,4,0,0" BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<CheckBox
						Grid.Row="0"
						Margin="4"
						IsChecked="{Binding OSCManualConfigCheckmark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Content="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.OSC.SendToManualEndpoint]}"
						ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.OSC.SendToManualEndpoint.Tooltip]}"
					/>
				</Border>
				<Border Margin="4,0,4,4" Padding="4" CornerRadius="0,0,4,4" BorderThickness="1,0,1,1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<StackPanel>
						<TextBlock
							Margin="8"
							VerticalAlignment="Center"
							IsEnabled="{Binding OSCManualConfigCheckmark}"
							Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.OSC.ManualEndpointConfig]}"
						/>
						
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>

							<TextBlock
								Grid.Row="0"
								Grid.Column="0"
								Margin="8"
								VerticalAlignment="Center"
								HorizontalAlignment="Right"
								IsEnabled="{Binding OSCManualConfigCheckmark}"
								Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.OSC.OSCIP]}"
							/>
							<TextBox
								Grid.Row="0"
								Grid.Column="1"
								Margin="4"
								Width="160"
								HorizontalAlignment="Left"
								IsEnabled="{Binding OSCManualConfigCheckmark}"
								Text="{Binding OSCIPText, UpdateSourceTrigger=PropertyChanged}"
								ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.OSC.OSCIP.Tooltip]}"
							>
								<TextBox.InputBindings>
									<KeyBinding Key="Enter" Command="{Binding OptionsOSCApplyCommand}"/>
								</TextBox.InputBindings>
							</TextBox>

							<TextBlock
								Grid.Row="1"
								Grid.Column="0"
								Margin="8"
								VerticalAlignment="Center"
								HorizontalAlignment="Right"
								IsEnabled="{Binding OSCManualConfigCheckmark}"
								Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.OSC.OSCPort]}"
							/>
							<TextBox
								Grid.Row="1"
								Grid.Column="1"
								Margin="4"
								Width="160"
								HorizontalAlignment="Left"
								IsEnabled="{Binding OSCManualConfigCheckmark}"
								Text="{Binding OSCPortText, UpdateSourceTrigger=PropertyChanged}"
								ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.OSC.OSCPort.Tooltip]}"
							>
								<TextBox.InputBindings>
									<KeyBinding Key="Enter" Command="{Binding OptionsOSCApplyCommand}"/>
								</TextBox.InputBindings>
							</TextBox>

							<TextBlock
								Grid.Row="2"
								Grid.Column="0"
								Margin="8"
								VerticalAlignment="Center"
								HorizontalAlignment="Right"
								IsEnabled="{Binding OSCManualConfigCheckmark}"
								Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.OSC.OSCPath]}"
							/>
							<TextBox
								Grid.Row="2"
								Grid.Column="1"
								Margin="4"
								IsEnabled="{Binding OSCManualConfigCheckmark}"
								Text="{Binding OSCPathText, UpdateSourceTrigger=PropertyChanged}"
								ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.OSC.OSCPath.Tooltip]}"
							>
								<TextBox.InputBindings>
									<KeyBinding Key="Enter" Command="{Binding OptionsOSCApplyCommand}"/>
								</TextBox.InputBindings>
							</TextBox>
						</Grid>
					</StackPanel>
				</Border>

			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
