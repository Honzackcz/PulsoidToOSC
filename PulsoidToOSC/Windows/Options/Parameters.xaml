<UserControl x:Class="PulsoidToOSC.Windows.Options.Parameters"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:PulsoidToOSC.ViewModels.Options"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="400"
			 d:DataContext="{d:DesignInstance Type=local:ParametersViewModel}">
	<Grid>
		<Grid Margin="4,4,0,4">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<TextBlock
				Margin="16"
				VerticalAlignment="Center"
				TextWrapping="Wrap"
				Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Parameters.Title]}"
				Style="{StaticResource TitleTextBlockStyle}"
			/>

			<Grid Grid.Row="1" Margin="4, 4, 22, 0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock
					Grid.Column="0"
					Margin="16,0"
					VerticalAlignment="Center"
					Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Parameters.List]}"
				/>
				<Button
					Grid.Column="2"
					Margin="4"
					Padding="8"
					Command="{Binding AddNewParameterCommand}"
					Content="&#xE710;"
					FontFamily="{StaticResource SymbolThemeFontFamily}"
					ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Parameters.Add.Tooltip]}"
					Style="{DynamicResource AccentButtonStyle}"
				/>
			</Grid>

			<ListView
				Grid.Row="2"
				Margin="4, 6, 0, 0"
				HorizontalContentAlignment="Stretch"
				ItemsSource="{Binding Parameters}"
				ScrollViewer.VerticalScrollBarVisibility="Visible"
				ScrollViewer.CanContentScroll="False"
			>
				<ListView.ItemContainerStyle>
					<Style TargetType="{x:Type ListViewItem}">
						<Setter Property="Background" Value="Transparent"/>
						<Setter Property="Template">
							<Setter.Value>
								<ControlTemplate TargetType="{x:Type ListViewItem}">
									<ContentPresenter/>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
					</Style>
				</ListView.ItemContainerStyle>

				<ListView.ItemTemplate>
					<DataTemplate>
						<Border Margin="0,2,16,2" Padding="4" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
							<Grid Margin="0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="150"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<ComboBox
									Grid.Column="0"
									Margin="4"
									HorizontalAlignment="Stretch"
									HorizontalContentAlignment="Left"
									ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Parameters.DataType.Tooltip]}"
									ItemsSource="{Binding ParameterType_Items}"
									SelectedItem="{Binding ParameterType_SelectedItem}"
								>
									<ComboBox.ItemTemplate>
										<DataTemplate>
											<TextBlock
												Text="{Binding ParameterType_ItemName}"
												ToolTip="{Binding ParameterType_ItemToolTip}"
											/>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>
								<TextBox
									Grid.Column="1"
									Margin="4"
									Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
									ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Parameters.Name.Tooltip]}"
								>
									<TextBox.InputBindings>
										<KeyBinding Key="Enter" Command="{Binding ApplyParameterCommand}"/>
									</TextBox.InputBindings>
								</TextBox>
								<Button
									Grid.Column="2"
									Margin="4"
									Padding="8"
									Command="{Binding DeleteParameterCommand}"
									Content="&#xE711;"
									FontFamily="{StaticResource SymbolThemeFontFamily}"
									ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Parameters.Delete.Tooltip]}"
								/>
							</Grid>
						</Border>
					</DataTemplate>
				</ListView.ItemTemplate>
			</ListView>
		</Grid>

	</Grid>
</UserControl>
