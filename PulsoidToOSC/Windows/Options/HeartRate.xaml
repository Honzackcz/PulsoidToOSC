<UserControl x:Class="PulsoidToOSC.Windows.Options.HeartRate"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:PulsoidToOSC.ViewModels.Options"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="400"
			 d:DataContext="{d:DesignInstance Type=local:HeartRateViewModel}">
	<Grid>
		<ScrollViewer>
			<StackPanel Margin="4,4,12,4">
				<TextBlock
					Margin="16"
					VerticalAlignment="Center"
					TextWrapping="Wrap"
					Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.Title]}"
					Style="{StaticResource TitleTextBlockStyle}"
				/>

				<Border Margin="4" Padding="4" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<StackPanel>
						<TextBlock
							Margin="8"
							VerticalAlignment="Center"
							Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.FloatRange]}"
						/>

						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="100"/>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="100"/>
							</Grid.ColumnDefinitions>
							<TextBlock
								Grid.Column="0"
								Margin="8"
								VerticalAlignment="Center"
								Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.FloatRange.Min]}"
							/>
							<TextBox
								Grid.Column="1"
								Margin="4"
								Text="{Binding HrFloatMinText, UpdateSourceTrigger=PropertyChanged}"
								ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.FloatRange.Min.Tooltip]}"
							>
								<TextBox.InputBindings>
									<KeyBinding Key="Enter" Command="{Binding OptionsHrApplyCommand}"/>
								</TextBox.InputBindings>
							</TextBox>

							<TextBlock
								Grid.Column="2"
								Margin="8"
								VerticalAlignment="Center"
								Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.FloatRange.Max]}"
							/>
							<TextBox
								Grid.Column="3"
								Margin="4"
								Text="{Binding HrFloatMaxText, UpdateSourceTrigger=PropertyChanged}"
								ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.FloatRange.Max.Tooltip]}"
							>
								<TextBox.InputBindings>
									<KeyBinding Key="Enter" Command="{Binding OptionsHrApplyCommand}"/>
								</TextBox.InputBindings>
							</TextBox>
						</Grid>
					</StackPanel>
				</Border>

				<Border Margin="4" Padding="4" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<StackPanel>
						<TextBlock
							Margin="8"
							VerticalAlignment="Center"
							Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.TrendRange]}"
						/>
						
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="100"/>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="100"/>
							</Grid.ColumnDefinitions>
							<TextBlock
								Grid.Column="0"
								Margin="8"
								VerticalAlignment="Center"
								Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.TrendRange.Min]}"
							/>
							<TextBox
								Grid.Column="1"
								Margin="4"
								Text="{Binding HrTrendMinText, UpdateSourceTrigger=PropertyChanged}"
								ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.TrendRange.Min.Tooltip]}"
							>
								<TextBox.InputBindings>
									<KeyBinding Key="Enter" Command="{Binding OptionsHrApplyCommand}"/>
								</TextBox.InputBindings>
							</TextBox>

							<TextBlock
								Grid.Column="2"
								Margin="8"
								VerticalAlignment="Center"
								Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.TrendRange.Max]}"
							/>
							<TextBox
								Grid.Column="3"
								Margin="4"
								Text="{Binding HrTrendMaxText, UpdateSourceTrigger=PropertyChanged}"
								ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.TrendRange.Max.Tooltip]}"
							>
								<TextBox.InputBindings>
									<KeyBinding Key="Enter" Command="{Binding OptionsHrApplyCommand}"/>
								</TextBox.InputBindings>
							</TextBox>
						</Grid>  
					</StackPanel>
				</Border>

				<Border Margin="4" Padding="4" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<StackPanel>
						<TextBlock
							Margin="8"
							VerticalAlignment="Center"
							Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.Offset]}"
						/>

						<TextBox
							Margin="4"
							Width="100"
							HorizontalAlignment="Left"
							Text="{Binding HrOffsetText, UpdateSourceTrigger=PropertyChanged}"
							ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.Offset.Tooltip]}"
						>
							<TextBox.InputBindings>
								<KeyBinding Key="Enter" Command="{Binding OptionsHrApplyCommand}"/>
							</TextBox.InputBindings>
						</TextBox>
					</StackPanel>
				</Border>

				<Border Margin="4" Padding="4" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<StackPanel>
						<TextBlock
							Margin="8"
							VerticalAlignment="Center"
							Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.UndesiredValues]}"
						/>

						<TextBox
							Margin="4"
							Text="{Binding HrUndesiredValuesText, UpdateSourceTrigger=PropertyChanged}"
							ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.UndesiredValues.Tooltip]}"
						>
							<TextBox.InputBindings>
								<KeyBinding Key="Enter" Command="{Binding OptionsHrApplyCommand}"/>
							</TextBox.InputBindings>
						</TextBox>
					</StackPanel>
				</Border>

				<Border Margin="4" Padding="4" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<CheckBox
						Margin="4"
						IsChecked="{Binding HrRandomValueCheckmark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Content="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.RandomValue]}"
						ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.HeartRate.RandomValue.Tooltip]}"
					/>
				</Border>

			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
