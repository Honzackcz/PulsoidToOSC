<UserControl x:Class="PulsoidToOSC.Windows.Options.VRChat"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:PulsoidToOSC.ViewModels.Options"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="400"
			 d:DataContext="{d:DesignInstance Type=local:VRChatViewModel}">
	<Grid>
		<ScrollViewer>
			<StackPanel Margin="4,4,12,4">
				<TextBlock
					Margin="16"
					VerticalAlignment="Center"
					TextWrapping="Wrap"
					Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.VRChat.Title]}"
					Style="{StaticResource TitleTextBlockStyle}"
				/>

				<Border Margin="4,4,4,0" Padding="4" CornerRadius="4,4,0,0" BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<CheckBox
						Margin="4"
						IsChecked="{Binding VRCAutoConfigCheckmark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Content="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.VRChat.UseVRCOSCQuery]}"
						ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.VRChat.UseVRCOSCQuery.Tooltip]}"
					/>
				</Border>
				<Border Margin="4,0,4,4" Padding="4" CornerRadius="0,0,4,4" BorderThickness="1,0,1,1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<CheckBox
						Margin="4"
						IsEnabled="{Binding VRCAutoConfigCheckmark}"
						IsChecked="{Binding VRCClinetsOnLANCheckmark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Content="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.VRChat.SendToAllVRCClients]}"
						ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.VRChat.SendToAllVRCClients.Tooltip]}"
					/>
				</Border>

				<Border Margin="4,4,4,0" Padding="4" CornerRadius="4,4,0,0" BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<CheckBox
						Margin="4"
						IsChecked="{Binding VRCChatboxCheckmark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Content="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.VRChat.SendToVRCChatbox]}"
						ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.VRChat.SendToVRCChatbox.Tooltip]}"
					/>
				</Border>
				<Border Margin="4,0,4,4" Padding="4" CornerRadius="0,0,4,4" BorderThickness="1,0,1,1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<StackPanel>
						<TextBlock
							Margin="8"
							VerticalAlignment="Center"
							IsEnabled="{Binding VRCChatboxCheckmark}"
							Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.VRChat.VRCChatboxMessage]}"
						/>
						<TextBox
							Margin="4"
							Height="Auto"
							IsEnabled="{Binding VRCChatboxCheckmark}"
							TextWrapping="Wrap"
							Text="{Binding VRCChatboxMessageText, UpdateSourceTrigger=PropertyChanged}"
							ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.VRChat.VRCChatboxMessage.Tooltip]}"
						>
							<TextBox.InputBindings>
								<KeyBinding Key="Enter" Command="{Binding OptionsVRChatApplyCommand}"/>
							</TextBox.InputBindings>
						</TextBox>
					</StackPanel>
				</Border>

			</StackPanel>
		 </ScrollViewer>
	</Grid>
</UserControl>
