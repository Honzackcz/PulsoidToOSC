<UserControl x:Class="PulsoidToOSC.Windows.Options.General"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:PulsoidToOSC.ViewModels.Options"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="400"
			 d:DataContext="{d:DesignInstance Type=local:GeneralViewModel}">
	<Grid>
		<ScrollViewer>
			<StackPanel Margin="4,4,12,4">
				<TextBlock
					Margin="16"
					VerticalAlignment="Center"
					TextWrapping="Wrap"
					Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.Title]}"
					Style="{StaticResource TitleTextBlockStyle}"
				/>

				<Border Margin="4,4,4,0" Padding="4" CornerRadius="4,4,0,0" BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<StackPanel>
						<TextBlock
							Margin="8"
							VerticalAlignment="Center"
							TextWrapping="Wrap"
							Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.GetPulsoidToken.Title]}"
							Style="{StaticResource SubtitleTextBlockStyle}"
						/>
						
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<Button
								Grid.Column="0"
								Margin="4"
								HorizontalAlignment="Stretch"
								Command="{Binding GetTokenCommand}"
								Content="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.GetPulsoidToken.Button]}"
								ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.GetPulsoidToken.Tooltip]}"
								Style="{DynamicResource AccentButtonStyle}"
							/>
							<TextBlock
								Grid.Column="1"
								Margin="8"
								VerticalAlignment="Center"
								TextWrapping="Wrap"
								Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.GetPulsoidToken.Text]}"
							/>
						</Grid>
					</StackPanel>
				</Border>
				<Border Margin="4,0,4,0" Padding="4" CornerRadius="0" BorderThickness="1,0,1,1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<StackPanel>
						<TextBlock
							Margin="8"
							VerticalAlignment="Center"
							TextWrapping="Wrap"
							Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.PulsoidTokenStatus.Text]}"
						/>

						<Grid>
							<StackPanel Orientation="Horizontal"  Visibility="{Binding TokenValidationValid}">
								<Label
									Margin="0,5"
									Padding="8,2,0,0"
									VerticalAlignment="Center"
									Content="&#xE930;"
									FontFamily="{StaticResource SymbolThemeFontFamily}"
									FontSize="28"
									Foreground="{DynamicResource SystemFillColorSuccessBrush}"
								/>
								<TextBlock
									Margin="8"
									VerticalAlignment="Center"
									TextWrapping="Wrap"
									Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.PulsoidTokenStatus.Valid.Text]}"
								/>
							</StackPanel>

							<StackPanel Orientation="Horizontal"  Visibility="{Binding TokenValidationInvalid}">
								<Label
									Padding="8,2,0,0"
									VerticalAlignment="Center"
									Content="&#xEA39;"
									FontFamily="{StaticResource SymbolThemeFontFamily}"
									FontSize="28"
									Foreground="{DynamicResource SystemFillColorCriticalBrush}"
								/>
								<TextBlock
									Margin="8"
									VerticalAlignment="Center"
									TextWrapping="Wrap"
									Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.PulsoidTokenStatus.Invalid.Text]}"
								/>
							</StackPanel>

							<ProgressBar
								Margin="6,0"
								MaxWidth="360"
								HorizontalAlignment="Left"
								VerticalAlignment="Center"
								IsIndeterminate="True"
								Visibility="{Binding TokenValidationIndicator}"
							/>
						</Grid>

					</StackPanel>
				</Border>
				<Border Margin="4,0,4,4" Padding="4" CornerRadius="0,0,4,4" BorderThickness="1,0,1,1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<StackPanel>
						<TextBlock
							Margin="8"
							VerticalAlignment="Center"
							TextWrapping="Wrap"
							Text="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.SetPulsoidToken.Text]}"
						/>

						<Grid Visibility="Visible">
							<Grid.ColumnDefinitions>
								<ColumnDefinition MaxWidth="330"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<Grid Grid.Column="0">
								<TextBox
									Margin="4"
									x:Name="TokenBox"
									GotFocus="GotFocusToken"
									LostFocus="LostFocusToken"
									Foreground="Transparent"
									Text="{Binding TokenText, UpdateSourceTrigger=PropertyChanged}"
									MaxLength="36"
									MaxLines="1"
									ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.SetPulsoidToken.Field.Tooltip]}"
									>
									<TextBox.InputBindings>
										<KeyBinding Key="Enter" Command="{Binding SetTokenCommand}"/>
									</TextBox.InputBindings>
								</TextBox>
								<TextBlock
									Margin="17,0"
									VerticalAlignment="Center"
									IsHitTestVisible="False"
									Text="{Binding TokenTextBlock, UpdateSourceTrigger=PropertyChanged}"
								/>
							</Grid>

							<Button
								Grid.Column="1"
								Margin="4"
								Padding="8"
								x:Name="SetTokenButton"
								Command="{Binding SetTokenCommand}"
								Content="&#xE724;"
								FontFamily="{StaticResource SymbolThemeFontFamily}"
								ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.SetPulsoidToken.Tooltip]}"
							/>
						</Grid>
					</StackPanel>
				</Border>

				<Border Margin="4,4,4,0" Padding="4" CornerRadius="4,4,0,0" BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<CheckBox
						Margin="4"
						IsChecked="{Binding AutoStartCheckmark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Content="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.AutoStart]}"
						ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.AutoStart.Tooltip]}"
					/>
				</Border>
				<Border Margin="4,0,4,4" Padding="4" CornerRadius="0,0,4,4" BorderThickness="1,0,1,1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<CheckBox
						Margin="4"
						IsEnabled="{Binding AutoStartCheckmark}"
						IsChecked="{Binding StartMinimizedCheckmark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Content="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.StartMinimized]}"
						ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.StartMinimized.Tooltip]}"
					/>
				</Border>

				<Border Margin="4" Padding="4" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<CheckBox
						Margin="4"
						IsChecked="{Binding MinimizeToTrayCheckmark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						Content="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.MinimizeToTray]}"
						ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.General.MinimizeToTray.Tooltip]}"
					/>
				</Border>

				<Border Margin="4" Padding="4" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="40"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBlock
							Grid.Column="0"
							Margin="4"
							VerticalAlignment="Center"
							HorizontalAlignment="Center"
							Text="&#xF2B7;"
							FontFamily="{StaticResource SymbolThemeFontFamily}"
							FontSize="20"
						/>
						<ComboBox
								Grid.Column="1"
								Margin="4"
								HorizontalAlignment="Stretch"
								HorizontalContentAlignment="Left"
								ToolTip="{Binding Source={StaticResource Locale}, Path=[OptionsWindow.Parameters.DataType.Tooltip]}"
								ItemsSource="{Binding Locale_Items}"
								SelectedItem="{Binding Locale_SelectedItem}"
							>
							<ComboBox.ItemTemplate>
								<DataTemplate>
									<TextBlock
										Text="{Binding LocaleName, UpdateSourceTrigger=PropertyChanged}"
									/>
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>
					</Grid>
				</Border>

			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
